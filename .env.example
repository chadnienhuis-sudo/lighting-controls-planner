# Copy this file to .env.local and fill in real values for your environment.
# See docs/development.md for how to obtain these from a local Supabase stack
# or a hosted project. docs/backend-migration-plan.md §9 is the source of
# truth for which env vars the backend migration introduces.

# Public URL of your Supabase project / local stack.
# Local default (from `supabase start`): http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=

# Public "anon" key used by the browser client. Safe to expose — RLS is what
# actually enforces data access, and the anon key has no privileges beyond it.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service role key. Bypasses RLS entirely — never ship to the
# browser. Only used by server actions / route handlers / scripts that need
# admin-level writes (e.g. granting an a_plus_staff tier via the admin UI).
SUPABASE_SERVICE_ROLE_KEY=
